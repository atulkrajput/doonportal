7:["$","main",null,{"children":[["$","$Lf",null,{"headline":"Inventory Management System & POS Software","subheadline":"Smart POS software for retail with real-time inventory tracking, barcode scanning, and sales analytics. Built for modern retail businesses.","ctaButtons":[{"label":"Request Demo","href":"#demo-form","variant":"primary"},{"label":"See How It Works","href":"#features","variant":"secondary"}],"image":{"src":"/images/products/inventory-pos-hero.png","alt":"Retail inventory POS software dashboard for managing stock and billing"}}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L11",null,{"problems":[{"title":"Slow Billing Process","description":"Manual billing leads to long queues, errors in pricing, and poor customer experience."},{"title":"Stock Mismanagement","description":"Without real-time tracking, businesses face stockouts, overstocking, and inventory shrinkage."},{"title":"No Purchase Visibility","description":"Managing suppliers, purchase orders, and payment tracking across spreadsheets is chaotic."},{"title":"Missing Business Insights","description":"Without proper reporting, business owners cannot identify top products, slow movers, or profit margins."}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L12",null,{"solution":{"title":"Sell Smarter, Stock Better","description":"DoonPortal Inventory POS System combines fast billing with intelligent inventory management. Scan barcodes, process sales instantly, track every item in real-time, and get actionable reports to grow your business."}}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","div",null,{"id":"features","children":["$","$L13",null,{"features":[{"icon":"🧾","title":"POS Billing","description":"Fast, accurate billing with barcode scanning, multiple payment modes, and customizable invoices."},{"icon":"📦","title":"Inventory Tracking","description":"Real-time stock levels, batch tracking, expiry management, and multi-location support."},{"icon":"🛒","title":"Purchase Management","description":"Purchase orders, goods receipt, supplier invoices, and payment tracking in one place."},{"icon":"🤝","title":"Supplier Management","description":"Supplier profiles, contact details, payment history, and performance tracking."},{"icon":"📷","title":"Barcode Scanning","description":"Generate and scan barcodes for quick product lookup, billing, and stock counting."},{"icon":"⚠️","title":"Stock Alerts","description":"Automated low-stock and expiry alerts to prevent stockouts and waste."},{"icon":"👥","title":"Customer Records","description":"Customer profiles, purchase history, loyalty tracking, and credit management."},{"icon":"📊","title":"Sales Reports","description":"Daily, weekly, and monthly sales reports with profit analysis, top products, and trend charts."}],"columns":3,"title":"Features"}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L14",null,{"screenshots":[{"src":"/images/products/pos-billing.png","alt":"POS Billing Interface","caption":"Fast and intuitive billing"},{"src":"/images/products/pos-inventory.png","alt":"Inventory Dashboard","caption":"Real-time inventory tracking"},{"src":"/images/products/pos-reports.png","alt":"Sales Reports","caption":"Comprehensive sales analytics"}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L15",null,{"benefits":[{"title":"Faster Checkout","description":"Barcode scanning and quick billing reduce checkout time by up to 70%."},{"title":"Never Run Out of Stock","description":"Automated alerts and reorder points ensure you always have what customers need."},{"title":"Increase Profit Margins","description":"Detailed reports help identify top sellers, slow movers, and optimize pricing."},{"title":"Scale with Confidence","description":"Multi-location support and cloud access let you grow without limits."}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":"$L16"}],"$L17","$L18","$L19"]}]
