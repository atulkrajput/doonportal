6:["$","div",null,{"id":"features","children":["$","$L10",null,{"features":[{"icon":"👨‍🎓","title":"Student Management","description":"Complete student profiles with enrollment, personal details, academic history, and document management."},{"icon":"📋","title":"Attendance Tracking","description":"Digital attendance with biometric or app-based marking, automated reports, and parent notifications."},{"icon":"💰","title":"Fee Management","description":"Flexible fee structures, online payment collection, automated receipts, and defaulter tracking."},{"icon":"📊","title":"Accounting","description":"Integrated accounting with income/expense tracking, balance sheets, and financial reports."},{"icon":"📚","title":"Library Management","description":"Book cataloging, issue/return tracking, fine management, and digital library access."},{"icon":"🚌","title":"Transport Management","description":"Route planning, vehicle tracking, driver management, and transport fee integration."},{"icon":"📝","title":"Exam Management","description":"Exam scheduling, hall ticket generation, mark entry, and result processing."},{"icon":"📄","title":"Report Card Generation","description":"Customizable report cards with grades, remarks, attendance summary, and performance graphs."},{"icon":"📱","title":"Parent App","description":"Dedicated mobile app for parents to view attendance, grades, fees, and communicate with teachers."},{"icon":"🔔","title":"Notifications","description":"Automated SMS, email, and push notifications for attendance, fees, exams, and announcements."},{"icon":"📈","title":"Analytics","description":"Dashboards and reports for student performance, attendance trends, fee collection, and operational insights."}],"columns":3,"title":"Features"}]}]
