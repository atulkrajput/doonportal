7:["$","main",null,{"children":[["$","$Lf",null,{"headline":"School Management Software","subheadline":"Complete school ERP to streamline administration, automate operations, and enhance learning outcomes. Trusted by schools across India.","ctaButtons":[{"label":"Request Demo","href":"#demo-form","variant":"primary"},{"label":"See How It Works","href":"#features","variant":"secondary"}],"image":{"src":"/images/products/school-management-hero.png","alt":"School ERP dashboard interface for managing student records and school administration"}}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L11",null,{"problems":[{"title":"Manual Record Keeping","description":"Schools waste hours on paper-based records for students, attendance, and fees, leading to errors and lost data."},{"title":"Disconnected Systems","description":"Using separate tools for fees, exams, library, and transport creates data silos and duplicated effort."},{"title":"Poor Parent Communication","description":"Parents lack real-time visibility into their child's attendance, grades, and school announcements."},{"title":"Complex Fee Management","description":"Tracking fee payments, generating receipts, and managing defaulters manually is time-consuming and error-prone."}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L12",null,{"solution":{"title":"One Platform for Everything","description":"DoonPortal School Management System unifies student records, attendance, fees, exams, library, transport, and parent communication into a single, easy-to-use platform. Automate repetitive tasks, eliminate paper, and give every stakeholder real-time access to the information they need."}}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","div",null,{"id":"features","children":["$","$L13",null,{"features":[{"icon":"👨‍🎓","title":"Student Management","description":"Complete student profiles with enrollment, personal details, academic history, and document management."},{"icon":"📋","title":"Attendance Tracking","description":"Digital attendance with biometric or app-based marking, automated reports, and parent notifications."},{"icon":"💰","title":"Fee Management","description":"Flexible fee structures, online payment collection, automated receipts, and defaulter tracking."},{"icon":"📊","title":"Accounting","description":"Integrated accounting with income/expense tracking, balance sheets, and financial reports."},{"icon":"📚","title":"Library Management","description":"Book cataloging, issue/return tracking, fine management, and digital library access."},{"icon":"🚌","title":"Transport Management","description":"Route planning, vehicle tracking, driver management, and transport fee integration."},{"icon":"📝","title":"Exam Management","description":"Exam scheduling, hall ticket generation, mark entry, and result processing."},{"icon":"📄","title":"Report Card Generation","description":"Customizable report cards with grades, remarks, attendance summary, and performance graphs."},{"icon":"📱","title":"Parent App","description":"Dedicated mobile app for parents to view attendance, grades, fees, and communicate with teachers."},{"icon":"🔔","title":"Notifications","description":"Automated SMS, email, and push notifications for attendance, fees, exams, and announcements."},{"icon":"📈","title":"Analytics","description":"Dashboards and reports for student performance, attendance trends, fee collection, and operational insights."}],"columns":3,"title":"Features"}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L14",null,{"screenshots":[{"src":"/images/products/school-dashboard.png","alt":"School Management Dashboard","caption":"Comprehensive admin dashboard"},{"src":"/images/products/school-attendance.png","alt":"Attendance Tracking Interface","caption":"Digital attendance tracking"},{"src":"/images/products/school-fees.png","alt":"Fee Management Module","caption":"Automated fee management"}]}]}],"$L15","$L16","$L17","$L18","$L19"]}]
