7:["$","main",null,{"children":[["$","$Lf",null,{"headline":"Dairy Farm Management Software","subheadline":"Complete cattle management software with milk production tracking, vendor management, fat/SNF calculations, and financial reporting for dairy farms.","ctaButtons":[{"label":"Request Demo","href":"#demo-form","variant":"primary"},{"label":"See How It Works","href":"#features","variant":"secondary"}],"image":{"src":"/images/products/dairy-management-hero.png","alt":"Dairy farm management software dashboard for tracking cattle and milk production"}}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L11",null,{"problems":[{"title":"Manual Cattle Records","description":"Tracking cattle health, breeding, and production data on paper is unreliable and hard to analyze."},{"title":"Inaccurate Milk Accounting","description":"Manual recording of daily milk production and vendor purchases leads to disputes and revenue loss."},{"title":"Complex Quality Calculations","description":"Fat and SNF testing, rate calculations, and payment processing are tedious without automation."},{"title":"No Financial Visibility","description":"Without proper expense tracking and reporting, dairy operators cannot assess true profitability."}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L12",null,{"solution":{"title":"Digitize Your Dairy Operations","description":"DoonPortal Dairy Management System automates every aspect of dairy farm operations. Record cattle data, track milk production, manage vendor purchases with fat/SNF calculations, and generate financial reports — all from one platform."}}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","div",null,{"id":"features","children":["$","$L13",null,{"features":[{"icon":"🐮","title":"Cattle Records","description":"Complete cattle profiles with breed, health records, vaccination schedules, and breeding history."},{"icon":"🥛","title":"Milk Production Tracking","description":"Daily milk recording per animal, shift-wise tracking, and production trend analysis."},{"icon":"🌾","title":"Feed Management","description":"Feed inventory, consumption tracking, diet planning, and cost analysis per animal."},{"icon":"🚚","title":"Vendor Milk Purchase","description":"Vendor registration, daily milk collection recording, and automated payment calculations."},{"icon":"🧪","title":"Fat/SNF Calculations","description":"Automated fat and SNF testing integration, rate charts, and quality-based pricing."},{"icon":"💸","title":"Expense Tracking","description":"Track all farm expenses including feed, veterinary, labor, equipment, and maintenance costs."},{"icon":"📑","title":"Financial Reports","description":"Profit/loss statements, vendor payment summaries, production reports, and cost analysis."}],"columns":3,"title":"Features"}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L14",null,{"screenshots":[{"src":"/images/products/dairy-dashboard.png","alt":"Dairy Management Dashboard","caption":"Farm operations at a glance"},{"src":"/images/products/dairy-production.png","alt":"Milk Production Tracking","caption":"Daily production monitoring"},{"src":"/images/products/dairy-vendor.png","alt":"Vendor Management","caption":"Vendor purchase management"}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":["$","$L15",null,{"benefits":[{"title":"Accurate Records","description":"Digital records eliminate errors and disputes in milk accounting and payments."},{"title":"Fair Pricing","description":"Automated fat/SNF calculations ensure transparent, quality-based pricing for vendors."},{"title":"Reduce Costs","description":"Feed optimization and expense tracking help identify savings opportunities."},{"title":"Grow Profitably","description":"Financial reports give clear visibility into farm profitability and growth areas."}]}]}],["$","$L10",null,{"variant":"fade-in-up","children":"$L16"}],"$L17","$L18","$L19"]}]
