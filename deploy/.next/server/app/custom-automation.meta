{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/custom-automation/layout,_N_T_/custom-automation/page,_N_T_/custom-automation"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/custom-automation/__PAGE__",
    "/custom-automation",
    "/_index",
    "/_head"
  ]
}