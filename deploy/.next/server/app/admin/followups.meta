{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/followups/layout,_N_T_/admin/followups/page,_N_T_/admin/followups"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/followups/__PAGE__",
    "/admin/followups",
    "/admin",
    "/_index",
    "/_head"
  ]
}