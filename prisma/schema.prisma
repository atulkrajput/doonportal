generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Lead {
  id              Int       @id @default(autoincrement())
  name            String
  organization    String?
  city            String?
  state           String?
  phone           String?
  email           String
  message         String?   @db.Text
  productInterest String    @map("product_interest")
  source          String    @default("website")
  status          String    @default("new")
  score           Int       @default(0)
  nextFollowupDate DateTime? @map("next_followup_date")
  followupStatus   String?   @map("followup_status")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  demoBookings    DemoBooking[]
  activities      Activity[]
  tags            LeadTag[]
  campaignLeads   CampaignLead[]
  whatsappLogs    WhatsappLog[]

  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([city])
  @@index([createdAt])
  @@map("leads")
}

model DemoBooking {
  id            Int      @id @default(autoincrement())
  leadId        Int      @map("lead_id")
  scheduledDate String   @map("scheduled_date")
  scheduledTime String   @map("scheduled_time")
  meetingLink   String?  @map("meeting_link")
  notes         String?  @db.Text
  status        String   @default("scheduled")
  createdAt     DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@index([scheduledDate])
  @@map("demo_bookings")
}

model Activity {
  id        Int      @id @default(autoincrement())
  leadId    Int      @map("lead_id")
  type      String
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@map("activities")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("sales")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model LeadTag {
  id      Int    @id @default(autoincrement())
  leadId  Int    @map("lead_id")
  tagName String @map("tag_name")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([leadId, tagName])
  @@index([leadId])
  @@index([tagName])
  @@map("lead_tags")
}

model Campaign {
  id        Int      @id @default(autoincrement())
  name      String
  type      String   // email / whatsapp / ads / manual
  product   String   // school / inventory / dairy
  status    String   @default("active") // active / paused / completed
  createdAt DateTime @default(now()) @map("created_at")

  campaignLeads CampaignLead[]

  @@index([status])
  @@index([type])
  @@map("campaigns")
}

model CampaignLead {
  id         Int      @id @default(autoincrement())
  campaignId Int      @map("campaign_id")
  leadId     Int      @map("lead_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([campaignId])
  @@index([leadId])
  @@map("campaign_leads")
}

model EmailTemplate {
  id      Int    @id @default(autoincrement())
  name    String
  subject String
  body    String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_templates")
}

model WhatsappLog {
  id        Int      @id @default(autoincrement())
  leadId    Int      @map("lead_id")
  message   String   @db.Text
  status    String   @default("sent") // sent / delivered / failed
  createdAt DateTime @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([status])
  @@map("whatsapp_logs")
}

model AutomationRule {
  id        Int      @id @default(autoincrement())
  name      String
  trigger   String   // new_lead / no_contact_2days / demo_completed
  action    String   // send_email / mark_followup / send_whatsapp
  templateId Int?    @map("template_id")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("automation_rules")
}
